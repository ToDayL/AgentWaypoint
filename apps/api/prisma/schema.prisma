generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  displayName      String?
  isActive         Boolean   @default(true)
  role             String    @default("user")
  authPolicy       String    @default("password_or_webauthn")
  passwordHash     String?
  lastLoginAt      DateTime?
  turnSteerEnabled Boolean   @default(false)
  defaultWorkspaceRoot String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  projects         Project[]
  authSessions     AuthSession[]
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  sessionTokenHash String    @unique
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  revokedAt        DateTime?
  ip               String?
  userAgent        String?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt, revokedAt])
}

model Project {
  id                    String    @id @default(cuid())
  ownerUserId           String
  name                  String
  repoPath              String?
  backend               String    @default("codex")
  backendConfig         Json?
  createdAt             DateTime  @default(now())
  sessions              Session[]
  owner                 User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
}

model Session {
  id                     String    @id @default(cuid())
  projectId              String
  title                  String
  status                 String
  codexThreadId          String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  messages               Message[]
  turns                  Turn[]
  project                Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Message {
  id         String    @id @default(cuid())
  sessionId  String
  role       String
  content    String
  tokenCount Int?
  createdAt  DateTime  @default(now())
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Turn {
  id                 String    @id @default(cuid())
  sessionId          String
  userMessageId      String?
  assistantMessageId String?
  status             String
  requestedCwd       String?
  requestedModel     String?
  requestedSandbox   String?
  requestedApprovalPolicy String?
  effectiveCwd       String?
  effectiveModel     String?
  effectiveSandbox   String?
  effectiveApprovalPolicy String?
  failureCode        String?
  failureMessage     String?
  contextRemainingRatio Decimal? @db.Decimal(5, 4)
  contextRemainingTokens Int?
  contextWindowTokens Int?
  contextUpdatedAt    DateTime?
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime  @default(now())
  session            Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  events             Event[]
  approvals          TurnApproval[]

  @@index([sessionId])
}

model TurnApproval {
  id         String   @id @default(cuid())
  turnId      String
  requestId   String
  kind        String
  status      String
  payload     Json
  decision    String?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  turn        Turn     @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@unique([turnId, requestId])
  @@index([turnId, status, createdAt])
}

model Event {
  id        String   @id @default(cuid())
  turnId    String
  seq       Int
  type      String
  payload   Json
  createdAt DateTime @default(now())
  turn      Turn     @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([turnId, seq])
}
