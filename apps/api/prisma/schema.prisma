generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  turnSteerEnabled Boolean   @default(false)
  createdAt        DateTime  @default(now())
  projects         Project[]
}

model Project {
  id                    String    @id @default(cuid())
  ownerUserId           String
  name                  String
  repoPath              String?
  defaultModel          String?
  defaultSandbox        String?
  defaultApprovalPolicy String?
  createdAt             DateTime  @default(now())
  sessions              Session[]
  owner                 User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
}

model Session {
  id                     String    @id @default(cuid())
  projectId              String
  title                  String
  status                 String
  cwdOverride            String?
  modelOverride          String?
  sandboxOverride        String?
  approvalPolicyOverride String?
  codexThreadId          String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  messages               Message[]
  turns                  Turn[]
  project                Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Message {
  id         String    @id @default(cuid())
  sessionId  String
  role       String
  content    String
  tokenCount Int?
  createdAt  DateTime  @default(now())
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Turn {
  id                 String    @id @default(cuid())
  sessionId          String
  userMessageId      String?
  assistantMessageId String?
  status             String
  requestedCwd       String?
  requestedModel     String?
  requestedSandbox   String?
  requestedApprovalPolicy String?
  effectiveCwd       String?
  effectiveModel     String?
  effectiveSandbox   String?
  effectiveApprovalPolicy String?
  failureCode        String?
  failureMessage     String?
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime  @default(now())
  session            Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  events             Event[]
  approvals          TurnApproval[]

  @@index([sessionId])
}

model TurnApproval {
  id         String   @id @default(cuid())
  turnId      String
  requestId   String
  kind        String
  status      String
  payload     Json
  decision    String?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  turn        Turn     @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@unique([turnId, requestId])
  @@index([turnId, status, createdAt])
}

model Event {
  id        String   @id @default(cuid())
  turnId    String
  seq       Int
  type      String
  payload   Json
  createdAt DateTime @default(now())
  turn      Turn     @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([turnId, seq])
}
