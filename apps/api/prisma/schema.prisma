generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id          String    @id @default(cuid())
  ownerUserId String
  name        String
  repoPath    String?
  createdAt   DateTime  @default(now())
  sessions    Session[]
  owner       User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
}

model Session {
  id        String    @id @default(cuid())
  projectId String
  title     String
  status    String
  codexThreadId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  turns     Turn[]
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Message {
  id         String    @id @default(cuid())
  sessionId  String
  role       String
  content    String
  tokenCount Int?
  createdAt  DateTime  @default(now())
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Turn {
  id                 String    @id @default(cuid())
  sessionId          String
  userMessageId      String?
  assistantMessageId String?
  status             String
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime  @default(now())
  session            Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  events             Event[]

  @@index([sessionId])
}

model Event {
  id        String   @id @default(cuid())
  turnId    String
  seq       Int
  type      String
  payload   Json
  createdAt DateTime @default(now())
  turn      Turn     @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([turnId, seq])
}
