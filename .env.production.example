# Production ports (kept separate from dev defaults)
PROD_NGINX_HTTPS_PORT=3443
PROD_RUNNER_PORT=5700

# TLS for nginx
NGINX_SERVER_NAME=localhost
NGINX_SSL_CERT_FILE=localhost.crt
NGINX_SSL_KEY_FILE=localhost.key
NGINX_SSL_TRUSTED_CERT_FILE=

# API runtime
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
AUTH_SESSION_COOKIE_NAME=aw_session
AUTH_SESSION_TTL_HOURS=168
AUTH_DEV_EMAIL_HEADER=0

# API -> runner
PROD_API_RUNNER_MODE=http
PROD_API_RUNNER_BASE_URL=http://host.docker.internal:5700
RUNNER_HTTP_TIMEOUT_MS=5000
RUNNER_AUTH_TOKEN=

# Runner host process
RUNNER_HOST=0.0.0.0
RUNNER_PORT=5700
RUNNER_BACKEND=codex
RUNNER_CODEX_BIN=codex
RUNNER_CODEX_CWD=
RUNNER_CODEX_MODEL=
RUNNER_CODEX_APPROVAL_POLICY=on-request
RUNNER_CODEX_SANDBOX=
RUNNER_ALLOWED_REPO_ROOTS=
DEFAULT_WORKSPACE_ROOT=

# DB/cache inside prod docker network
PROD_API_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/agentwaypoint_prod
PROD_POSTGRES_DB=agentwaypoint_prod
PROD_POSTGRES_USER=postgres
PROD_POSTGRES_PASSWORD=postgres
# Optional mount source for persistence:
# - leave empty to use named volume (default)
# - set absolute host path for bind mount (example: /srv/agentwaypoint/postgres)
PROD_POSTGRES_DATA_MOUNT=
PROD_API_REDIS_URL=redis://redis:6379
# Optional mount source for persistence:
# - leave empty to use named volume (default)
# - set absolute host path for bind mount (example: /srv/agentwaypoint/redis)
PROD_REDIS_DATA_MOUNT=

# Web -> API in docker network
NEXT_PUBLIC_API_BASE_URL=http://api:4000
WEB_API_BASE_URL=http://api:4000

# Optional proxy
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,api,postgres,redis,host.docker.internal
