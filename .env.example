# Runtime
NODE_ENV=development
PORT=4000
WEB_PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codexpanel

# Optional cache
REDIS_URL=redis://localhost:6379

# Optional proxy (leave empty if not needed)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis

# Auth (MVP placeholders)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
