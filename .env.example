# Runtime
NODE_ENV=development
PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://api:4000
WEB_API_BASE_URL=http://api:4000
NGINX_HTTPS_PORT=3000
NGINX_SERVER_NAME=localhost
NGINX_SSL_CERT_FILE=localhost.crt
NGINX_SSL_KEY_FILE=localhost.key
NGINX_SSL_TRUSTED_CERT_FILE=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentwaypoint
API_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/agentwaypoint

# Optional cache
REDIS_URL=redis://localhost:6379
API_REDIS_URL=redis://redis:6379

# Optional proxy (leave empty if not needed)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,api,postgres,redis,host.docker.internal

# Auth (MVP placeholders)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Runner adapter
RUNNER_MODE=mock
RUNNER_BASE_URL=http://127.0.0.1:4700
RUNNER_HTTP_TIMEOUT_MS=5000
RUNNER_AUTH_TOKEN=
TURN_STEER_ENABLED=false
API_RUNNER_MODE=http
API_RUNNER_BASE_URL=http://host.docker.internal:4700
RUNNER_HOST=0.0.0.0
RUNNER_PORT=4700
RUNNER_BACKEND=codex
RUNNER_CODEX_BIN=codex
RUNNER_CODEX_CWD=
RUNNER_CODEX_MODEL=
RUNNER_CODEX_APPROVAL_POLICY=on-request
RUNNER_CODEX_SANDBOX=
RUNNER_ALLOWED_REPO_ROOTS=
