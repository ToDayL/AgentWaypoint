# Runtime
NODE_ENV=development
PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_BASE_URL=http://host.docker.internal:4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codexpanel

# Optional cache
REDIS_URL=redis://localhost:6379

# Optional proxy (leave empty if not needed)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis

# Auth (MVP placeholders)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Runner adapter
RUNNER_MODE=mock
RUNNER_BASE_URL=http://127.0.0.1:4700
RUNNER_HTTP_TIMEOUT_MS=5000
RUNNER_AUTH_TOKEN=
RUNNER_HOST=127.0.0.1
RUNNER_PORT=4700
RUNNER_API_BASE_URL=http://127.0.0.1:4000
